# ─── AEGIS Environment Variables ───────────────────────────────────────────────
# Copy this file to .env and fill in the values before running the project.
#
# Required
DATABASE_URL=postgresql://user:password@localhost:5432/aegis

# Required for session security (any long random string, e.g. `openssl rand -hex 32`)
SESSION_SECRET=change-me-to-a-long-random-string

# Optional — override default ports
# PORT defaults are set per-service in artifact.toml; only set these to override
# API_PORT=8080
# WEB_PORT=5173
